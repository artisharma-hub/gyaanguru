# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (running directly, not Docker):
#   DATABASE_URL=postgresql+asyncpg://gyaan:gyaan123@localhost:5432/gyaan_guru
# Docker (docker-compose sets this via service name — do not change):
#   DATABASE_URL=postgresql+asyncpg://gyaan:gyaan123@db:5432/gyaan_guru
# Production (Render / Railway / Aiven / Supabase) — replace placeholders:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev:   REDIS_URL=redis://localhost:6379/0
# Docker:      REDIS_URL=redis://redis:6379/0
# Production (Upstash / Redis Cloud):
REDIS_URL=redis://default:PASSWORD@HOST:PORT/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Use a long random string in production (min 32 chars)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=720

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
# Render/Railway inject PORT automatically; 8000 is the local/Docker default
PORT=8000
